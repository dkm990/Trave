# ============================================================================
# docker-compose root .env — переменные для VPS-деплоя.
# Скопируй в .env и заполни. НЕ коммитить.
#
#   cp .env.example .env
#
# Дополнительно нужен backend/.env (см. backend/.env.example) — туда идут
# секреты приложения (BOT_TOKEN, GEMINI_API_KEY, и т.п.).
# ============================================================================

# Домен Mini App. Caddy выпустит сертификат Let's Encrypt автоматически.
# DNS A/AAAA-запись должна указывать на этот VPS до запуска compose.
MINI_APP_DOMAIN=yo.example.com

# Пустая строка = фронт ходит на тот же origin (Caddy проксирует /api → api:8000).
# Если хочешь хостить frontend отдельно, поставь полный URL backend.
VITE_API_BASE_URL=

# Куда писать SQLite внутри контейнера. Volume yo_data маунтится в /app/data.
DATABASE_URL=sqlite+aiosqlite:////app/data/yo.db

# Production обязательно 0. Иначе Mini App пускает любого по X-Telegram-User-Id.
DEV_ALLOW_INSECURE_AUTH=0

# Postgres (используется только с docker-compose.postgres.yml override).
POSTGRES_USER=yo
POSTGRES_DB=yo
# POSTGRES_PASSWORD=<сгенерировать>
