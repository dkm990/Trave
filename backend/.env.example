# =========================
# Yo backend — env example
# =========================
# Скопируй в backend/.env и заполни. НИКОГДА не коммить .env с реальными значениями.

# --- Telegram ---
# Получи токен у @BotFather (команда /newbot)
BOT_TOKEN=

# Альтернативное имя той же переменной (legacy)
TELEGRAM_BOT_TOKEN=

# Username бота без @
TELEGRAM_BOT_USERNAME=

# Публичный HTTPS URL Mini App. Для локальной разработки — туннель:
#   cloudflared tunnel --url http://localhost:5173
WEBAPP_URL=https://example.com
MINI_APP_URL=

# --- Backend ---
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000
API_BASE_URL=http://localhost:8000

# Timezone для today summary (IANA name). Для Турции: Europe/Istanbul.
# Для Вьетнама: Asia/Ho_Chi_Minh. По умолчанию UTC.
APP_TIMEZONE=UTC

# Dev mode: разрешает Mini App без валидации initData.
DEV_ALLOW_INSECURE_AUTH=1

# --- Database ---
DATABASE_URL=sqlite+aiosqlite:///./yo.db

# --- Currency ---
CURRENCY_PROVIDER=frankfurter
FRANKFURTER_BASE_URL=https://api.frankfurter.dev/v1
CURRENCY_CACHE_TTL_HOURS=12
DEFAULT_BASE_CURRENCY=RUB
# Опционально: ключ для платного fallback-провайдера. В MVP не используется.
EXCHANGERATE_API_KEY=

# --- AI ---
# rule_based | gemini | ollama
AI_PROVIDER=rule_based
AI_FALLBACK_PROVIDER=rule_based

# Gemini (опционально). Если AI_PROVIDER=gemini и GEMINI_API_KEY пуст —
# фабрика молча откатится на rule_based.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_SECONDS=8
GEMINI_RETRY_COUNT=1
GEMINI_USE_CONTEXT_CACHE=false

# Ollama (legacy/optional)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# --- CORS ---
CORS_ORIGINS=*

# Flights
FLIGHT_PROVIDER=mock
AERODATABOX_API_KEY=
AERODATABOX_API_HOST=aerodatabox.p.rapidapi.com
FLIGHT_PROVIDER_CACHE_TTL_SECONDS=300
FLIGHT_REFRESH_MIN_SECONDS=600
